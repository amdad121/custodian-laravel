{
    "name": "amdadulhaq/custodian-laravel",
    "description": "Custodian is a role and permission management system for Laravel",
    "keywords": [
        "Amdadul Haq",
        "laravel",
        "custodian-laravel",
        "roles",
        "permissions",
        "acl",
        "authorization"
    ],
    "homepage": "https://github.com/amdad121/custodian-laravel",
    "license": "MIT",
    "authors": [
        {
            "name": "Amdadul Haq",
            "email": "amdadulhaq781@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4|^8.5",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "AmdadulHaq\\Custodian\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AmdadulHaq\\Custodian\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "refactor": "vendor/bin/rector process",
        "refactor:check": "vendor/bin/rector process --dry-run",
        "lint": "vendor/bin/pint",
        "lint:check": "vendor/bin/pint --test"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "optimize-autoloader": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "AmdadulHaq\\Custodian\\CustodianServiceProvider"
            ],
            "aliases": {
                "Custodian": "AmdadulHaq\\Custodian\\Facades\\Custodian"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
